{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindspore-skills.dev/schema/portable-question-1.0.0.json",
  "title": "Readiness Portable Question",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "header",
    "question",
    "multi_select",
    "options",
    "response_binding"
  ],
  "properties": {
    "header": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "multi_select": {
      "type": "boolean",
      "const": false
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value", "label"],
        "properties": {
          "value": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "recommended": {
            "type": "boolean"
          },
          "source_option_index": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "manual_hint": {
      "type": "string",
      "minLength": 1
    },
    "selection_strategy": {
      "type": "string",
      "minLength": 1
    },
    "full_option_count": {
      "type": "integer",
      "minimum": 0
    },
    "response_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "format"],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "pattern": "^--confirm [A-Za-z0-9_.-]+=<value>$"
        }
      }
    }
  }
}
